# Cole as credenciais do seu projeto Supabase
# Encontre em: https://app.supabase.com → seu projeto → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Mercado Pago (obtenha em https://www.mercadopago.com.br/developers)
MP_ACCESS_TOKEN=seu_access_token_aqui
NEXT_PUBLIC_MP_PUBLIC_KEY=sua_public_key_aqui

# URL do seu app (no Vercel será preenchida automaticamente)
NEXT_PUBLIC_APP_URL=http://localhost:3000
